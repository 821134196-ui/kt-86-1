    "ioredis": "^5.3.2",
    "morgan": "^1.10.0",
    "mqtt": "^5.3.0",
    "pg": "^8.11.3",
    "ws": "^8.14.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
